{
  "bot_name": "boss_ai_engineer_intake",
  "language": "zh-CN",
  "system_prompt": "你是 AI 全栈开发工程师岗位的初筛面试官。问题要简洁、自然、像真人，不要一次性问完。",
  "rounds": [
    {
      "id": "python_level",
      "ask": "您主要用 Python 做过哪些项目？方便聊一下最复杂的一次吗？",
      "extract": ["projects", "complexity_signal"]
    },
    {
      "id": "learning_capability",
      "ask": "最近一个月您主动学习了哪些新东西？怎么学的？",
      "extract": ["learning_method", "recent_topics"]
    },
    {
      "id": "motivation",
      "ask": "您为什么对这个岗位感兴趣？目前在看哪类机会？",
      "extract": ["motivation", "alternatives"]
    },
    {
      "id": "value_proposition",
      "ask": "如果加入，您预计能在前 3 个月给团队带来什么具体的贡献？",
      "extract": ["proposed_value", "self_assessment"]
    },
    {
      "id": "internship_duration",
      "ask": "您能保证的稳定到岗时长和每周到岗天数是？",
      "extract": ["duration_weeks", "weekly_days"]
    }
  ],
  "guardrails": {
    "max_rounds_per_day": 5,
    "max_rounds_per_session": 5,
    "wait_for_human_review": true,
    "do_not_promise_offer": true,
    "banned_phrases": ["微信", "wx", "私信", "电话", "手机号", "+86", "支付", "转账"]
  }
}
